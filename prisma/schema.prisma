generator client {
  provider = "prisma-client"
}

datasource db {
  provider = "sqlite"
}

enum Currency {
  TOMAN
  USD
  IQD
}

model Customer {
  id          Int      @id @default(autoincrement())
  firstName   String
  lastName    String
  phoneNumber String?  @unique
  cardNumber  String?  @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  balances CustomerBalance[]
  logs     BalanceLog[]
}

model CustomerBalance {
  id         Int      @id @default(autoincrement())
  customerId Int
  currency   Currency
  balance    Int      @default(0)
  updatedAt  DateTime @updatedAt

  customer Customer     @relation(fields: [customerId], references: [id])
  logs     BalanceLog[]

  @@unique([customerId, currency])
}

model BalanceLog {
  id         Int      @id @default(autoincrement())
  customerId Int
  balanceId  Int? // 👈 مهم: اتصال به CustomerBalance
  currency   Currency
  amount     Int
  note       String?
  createdAt  DateTime @default(now())

  customer Customer         @relation(fields: [customerId], references: [id])
  balance  CustomerBalance? @relation(fields: [balanceId], references: [id])

  @@index([customerId, currency])
  @@index([balanceId])
}
